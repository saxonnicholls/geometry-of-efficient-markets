# The Geometry of Efficient Markets — API Keys
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# FRED (Federal Reserve Economic Data)
# Get your free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# 1. Go to https://fredaccount.stlouisfed.org/login/securepage/
# 2. Create a free account (or sign in)
# 3. Go to "My Account" → "API Keys" → "Request API Key"
# 4. Copy the key here
FRED_API_KEY=your_fred_api_key_here

# Databento (market data — equities, futures, options, crypto)
# https://databento.com — requires paid subscription
# SDK: pip install databento
DATABENTO_API_KEY=your_databento_key_here

# Massive (formerly Polygon.io) — equities, options, crypto, forex
# https://massive.com
MASSIVE_API_KEY=your_massive_key_here

MASSIVE_S3_ACCESS_KEY_ID=
MASSIVE_S3_SECRET_ACCESS_KEY=
MASSIVE_S3_ENDPOINT_URL=
MASSIVE_S3_BUCKET_NAME=

